<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
    <!-- Views -->
      <record id="sale_pedidos_view" model="ir.ui.view">
         <field name="name">sale.pedidos.form</field>
         <field name="model">sale.pedidos</field>
         <field name='type'>form</field>
         <field name="arch" type="xml">
            <form string='sale.pedidos.form'>
               <group>
                 <field name="file_input" string="Upload" class="oe_highlight" type="object"/>
                 <!-- <field name="cliente" string="Cliente"/> -->

               </group>

               <group>
                 <xpath expr="//button[9]" position="after">                
                   <button name="import_pedido"  string="Validar" class="oe_highlight" type="object"/>
                   <button name="gerar_fatura"  string="Gerar Pedido" class="oe_highlight" type="object"/>

                 </xpath> 
               </group>
               <group>
               <group string="Cabecalho">
                <field name="sale_id"/>
                <field name="tipo_registro_itp"/>
                <field name="ident_transacao" />
                <field name="versao_transacao"/>
                <field name="controle_movto"/>
                <field name="geracao_movto"/>
                <field name="hora_movto"/>
                <field name="gcg_transmissor"/>
               </group>
               <group>
               <group string="Informacoes da Compra">
                <field name="tipo_registro_pa1"/>
                <field name="dt_programatu"/>
                <field name="ord_compra"/>
                <field name="desc_itm"/>
                <field name="tipo_pedido"/>
                <field name="item_iveco"/>
                <field name="pedido_compra"/>
                <field name="linha_pedido" />
                <field name="cod_clie"/>
               </group>
              </group>
               <group string="Informacoes do Pedido">
                 <field name="codigo_pedido" />
                 <field name="dt_entrega" />
                 <field name="status_entrega" />
                 <field name="qtde_chamadas" />
                 <field name="valor_unitario" widget='monetary' options="{'currency': %(base.BRL)d}" />                 

               </group>
               <group string="Valor Total">
                <field name="faturamento" widget='monetary' options="{'currency': %(base.BRL)d}"/>
               </group>
             </group>
            </form>

         </field>
      </record>

   <!-- TREE -->
    <record id='sale_pedidos_view_form' model='ir.ui.view'>
        <field name='name'>sale.pedidos.tree</field>
        <field name='model'>sale.pedidos</field>
        <field name='type'>tree</field>
        <field name='arch' type='xml'>
        <tree string='sale_pedidos.tree'>
          <field name="codigo_pedido" />
          <field name="dt_entrega" />
          <field name="status_entrega" />
          <field name="qtde_chamadas" />
          <field name="valor_unitario" /> 
          <field name="faturamento" /> 
        </tree>
        </field>
    </record>

    <!-- ACTION -->
    <record id='sale_pedidos_view_action' model='ir.actions.act_window'>
        <field name='name'>Remessa Pedidos</field>
        <field name='res_model'>sale.pedidos</field>
<!--        <field name='view_type'>form</field> -->
        <field name='view_mode'>tree,form</field>
    </record>

     <!-- MENU  -->
     <menuitem name='Remessa Pedidos' id='sale_pedidos_view_menu'  action='sale_pedidos_view_action'/>



    </data>
</odoo>

